{
  "name": "toolbox",
  "version": "1.0.0",
  "description": "291 free online tools. 100% client-side processing.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:ci": "playwright test --reporter=html",
    "test:mobile": "playwright test --project='Mobile Chrome'",
    "test:debug": "playwright test --debug",
    "test:coverage": "playwright test --reporter=html && npx playwright show-report",
    "test:unit": "vitest run"
  },
  "keywords": [
    "tools",
    "online-tools",
    "pdf",
    "image",
    "video",
    "client-side"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "docx": "^9.6.1",
    "docx-pdf": "^0.0.1",
    "exif-js": "^2.3.0",
    "heic2any": "^0.0.4",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.3",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "main": "playwright.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamer4osman/xtoolbox.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/tamer4osman/xtoolbox/issues"
  },
  "homepage": "https://github.com/tamer4osman/xtoolbox#readme"
}
