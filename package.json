{
  "name": "toolbox",
  "version": "1.0.0",
  "description": "314 free online tools. 100% client-side processing.",
  "keywords": [
    "client-side",
    "image",
    "online-tools",
    "pdf",
    "tools",
    "video"
  ],
  "homepage": "https://github.com/tamer4osman/xtoolbox#readme",
  "bugs": {
    "url": "https://github.com/tamer4osman/xtoolbox/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamer4osman/xtoolbox.git"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "type": "module",
  "main": "playwright.config.js",
  "scripts": {
    "predev": "node scripts/copy-ffmpeg-core.mjs",
    "dev": "vite",
    "copy:ffmpeg-core": "node scripts/copy-ffmpeg-core.mjs",
    "prebuild": "node scripts/copy-ffmpeg-core.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint src",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:ci": "playwright test --reporter=html",
    "test:mobile": "playwright test --project='Mobile Chrome'",
    "test:debug": "playwright test --debug",
    "test:coverage": "playwright test --reporter=html && npx playwright show-report",
    "test:unit": "vitest run",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "docx": "^9.6.1",
    "exif-js": "^2.3.0",
    "heic2any": "^0.0.4",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.6",
    "mathjs": "^15.2.0",
    "onnxruntime-web": "^1.21.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "read-excel-file": "^9.2.0",
    "tesseract.js": "^7.0.0",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^11.2.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.72.0",
    "size-limit": "^11.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.4"
  },
  "size-limit": [
    {
      "name": "Main bundle (initial load)",
      "path": "dist/assets/index-*.js",
      "limit": "200 kB",
      "gzip": true
    },
    {
      "name": "Total JS (all chunks)",
      "path": "dist/assets/*.js",
      "limit": "2 MB",
      "gzip": true
    }
  ]
}
